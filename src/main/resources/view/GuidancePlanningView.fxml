<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Text?>

<!-- Phase 1 Planning View -->
<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.GuidancePlanningController" prefHeight="400.0" prefWidth="600.0" stylesheets="@../css/guidance.css">
    <BorderPane>
        <top>
            <Text id="title" BorderPane.alignment="TOP_CENTER" text="Phase 1: Planning"/>
        </top>
        <bottom>
            <HBox spacing="10" BorderPane.alignment="BOTTOM_CENTER" alignment="CENTER">
                <Button fx:id="startVisualization" text="Start Visualization" onAction="#onStartVisualizationClicked"/>
                <Button fx:id="loadPuncturePath" text="Load puncture path" onAction="#onLoadPuncturePathClicked"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>