<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>

<!-- Phase 1 Planning View -->
<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.GuidancePlanningController" prefHeight="400.0" prefWidth="600.0">
    <HBox spacing="10" AnchorPane.bottomAnchor="50" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" alignment="CENTER">
            <Button fx:id="startVisualization" text="Start Visualization" onAction="#onStartVisualizationClicked"/>
            <Button fx:id="loadPuncturePath" text="Load puncture path" onAction="#onLoadPuncturePathClicked"/>
    </HBox>
</AnchorPane>