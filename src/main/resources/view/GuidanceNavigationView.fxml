<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.Group?>

<!-- Phase 2 Navigation View -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.GuidanceNavigationController" prefHeight="400.0" prefWidth="600.0" stylesheets="@../css/navigation.css">
    <Group StackPane.alignment="CENTER">
        <Circle id="outerCircle" radius="200" centerX="0" centerY="0"/>
        <Circle id="innerCircle" radius="100" centerX="0" centerY="0"/>
        <Line id="innerLine" startX="-200" startY="0"    endX="200" endY="0"/>
        <Line id="innerLine" startX="0"    startY="-200" endX="0"   endY="200"/>
    </Group>
    <BorderPane>
        <left>
            <VBox id="trafficLightVBox" spacing="10" BorderPane.alignment="TOP_LEFT" maxHeight="180" alignment="CENTER">
                <BorderPane.margin>
                    <Insets bottom="20" left="20" right="0" top="20"/>
                </BorderPane.margin>
                <padding>
                    <Insets top="3" right = "3" left="3" bottom="3"/>
                </padding>
                <Circle id="trafficLight1" radius="35" centerX ="45" centerY="20"/>
                <Circle id="trafficLight2" radius="35" centerX ="45" centerY="60"/>
                <Circle id="trafficLight3" radius="35" centerX ="45" centerY="100"/>
            </VBox>
        </left>
        <right>
            <VBox id="depthVBox" BorderPane.alignment="BOTTOM_RIGHT" alignment="CENTER" maxHeight="400" >
                <BorderPane.margin>
                    <Insets bottom="20" left="20" right="20" top="20"/>
                </BorderPane.margin>
                <Line id="depthSeparator" startX="150" endX="250" startY="0" endY="0"/>
            </VBox>
        </right>
        <bottom>
            <StackPane alignment="BOTTOM_CENTER">
                <HBox spacing="0" alignment="BOTTOM_CENTER">
                    <Button fx:id="stopVisualization" text="Stop Visualization" onAction="#onStopVisualizationClicked"/>
                </HBox>
                <HBox spacing="0" alignment="BOTTOM_RIGHT" mouseTransparent="true">
                    <StackPane.margin>
                        <Insets bottom="0" left="0" right="40" top="0"/>
                    </StackPane.margin>
                    <Label text="Depth: "/>
                </HBox>
            </StackPane>
        </bottom>
    </BorderPane>
</StackPane>
