<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.Group?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.text.Text?>

<!-- Phase 2 Alignment View -->
<?import javafx.scene.shape.Rectangle?>
<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.GuidanceAlignmentController" prefHeight="400.0" prefWidth="600.0" stylesheets="@../css/guidance.css">
    <Group StackPane.alignment="CENTER">
        <Circle id="outerCircle" radius="200" centerX="0" centerY="0"/>
        <Circle id="innerCircle" radius="100" centerX="0" centerY="0"/>
        <Line id="innerLine" startX="-200" startY="0"    endX="200" endY="0"/>
        <Line id="innerLine" startX="0"    startY="-200" endX="0"   endY="200"/>
        <Group fx:id="targetCross" StackPane.alignment="CENTER">
            <Line startX="-10" startY="-10" endX="10" endY="10"/>
            <Line startX="-10" startY="10"  endX="10" endY="-10"/>
        </Group>
        <Circle id="targetCircle" fx:id="targetCircle" visible="false" centerX="0" centerY="0" radius="10"/>
    </Group>
    <BorderPane>
        <left>
            <VBox id="trafficLightVBox" spacing="10" BorderPane.alignment="TOP_LEFT" maxHeight="180" alignment="CENTER">
                <BorderPane.margin>
                    <Insets bottom="20" left="20" right="0" top="20"/>
                </BorderPane.margin>
                <padding>
                    <Insets top="3" right = "3" left="3" bottom="3"/>
                </padding>
                <Circle fx:id="tLight1" id="glowTrafficLight1" radius="35" centerX ="45" centerY="20"/>
                <Circle fx:id="tLight2" id="trafficLight2" radius="35" centerX ="45" centerY="60"/>
                <Circle fx:id="tLight3" id="trafficLight3" radius="35" centerX ="45" centerY="100"/>
            </VBox>
        </left>
        <right>
            <Group>
                <BorderPane.margin>
                    <Insets top="400" bottom="0" right="30" left="0"/>
                </BorderPane.margin>
                <Rectangle height="300" width="150" fill="#333"/>
                <Rectangle fx:id="fillRect" height="0" width="150" fill="limegreen"/>
                <Line startX="-25" endX="175" startY="100" endY="100" />
                <Label text="Entry" layoutX="-40" layoutY="100"/>
                <Line startX="-25" endX="175" startY="300" endY="300" />
                <Label text="Target" layoutX="-40" layoutY="300"/>
                <Label fx:id="depth" text="Depth: " layoutX="40" layoutY="320"/>
            </Group>
        </right>
        <bottom>
            <StackPane alignment="BOTTOM_CENTER">
                <HBox spacing="0" alignment="BOTTOM_CENTER">
                    <Button fx:id="stopVisualization" text="Stop Visualization" onAction="#onStopVisualizationClicked"/>
                </HBox>
                <HBox spacing="0" alignment="BOTTOM_RIGHT" mouseTransparent="true">
                    <StackPane.margin>
                        <Insets bottom="0" left="0" right="90" top="0"/>
                    </StackPane.margin>
                </HBox>
            </StackPane>
        </bottom>
        <top>
            <Text fx:id="title" id="title" BorderPane.alignment="CENTER" text="Phase 2: Tip Alignment"/>
        </top>
    </BorderPane>
</StackPane>
